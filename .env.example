# Fashion AI System - Environment Variables

# === МОДЕЛИ ===
# Путь к fine-tuned YOLO модели
# Скачать: https://github.com/switchablenorms/DeepFashion2
# Или использовать стандартную: yolov8n.pt, yolov8s.pt
FASHION_MODEL=yolov8n.pt

# === WEATHER API ===
# Получить ключ: https://openweathermap.org/api
# Бесплатный тариф: 1000 запросов/день
WEATHER_API_KEY=your_openweathermap_api_key_here

# === ДАННЫЕ ===
# Путь для хранения профилей пользователей
DATA_DIR=./data

# === API ===
# Порт для FastAPI
PORT=8000

# === ML ===
# Устройство для inference (auto/cpu/cuda)
DEVICE=auto
